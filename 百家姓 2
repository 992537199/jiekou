(function() {
    'use strict';

    const charMap = {
        '赵': '0', '钱': '1', '孙': '2', '李': '3', '周': '4', '吴': '5', '郑': '6', '王': '7', '冯': '8', '陈': '9',
        '褚': 'a', '卫': 'b', '蒋': 'c', '沈': 'd', '韩': 'e', '杨': 'f', '朱': 'g', '秦': 'h', '尤': 'i', '许': 'j',
        '何': 'k', '吕': 'l', '施': 'm', '张': 'n', '孔': 'o', '曹': 'p', '严': 'q', '华': 'r', '金': 's', '魏': 't',
        '陶': 'u', '姜': 'v', '戚': 'w', '谢': 'x', '邹': 'y', '喻': 'z',
        '福': 'A', '水': 'B', '窦': 'C', '章': 'D', '云': 'E', '苏': 'F', '潘': 'G', '葛': 'H', '奚': 'I', '范': 'J',
        '彭': 'K', '郎': 'L', '鲁': 'M', '韦': 'N', '昌': 'O', '马': 'P', '苗': 'Q', '凤': 'R', '花': 'S', '方': 'T',
        '俞': 'U', '任': 'V', '袁': 'W', '柳': 'X', '唐': 'Y', '罗': 'Z',
        '薛': '.', '伍': '-', '余': '_', '米': '+', '贝': '=', '姚': '/', '孟': '?', '顾': '#', '尹': '%', '江': '&', '钟': '*','竺': ':'
    };

    // 保留：只匹配 连续2个及以上 的字符，单个字符不转换（防乱码）
    const baijiaxingChars = Object.keys(charMap).join('');
    const regex = new RegExp(`[${baijiaxingChars}]{5,}`, 'g');

    // 文本转换
    function convertText(text) {
        return text.replace(regex, (match) => {
            let result = '';
            for (const char of match) {
                result += charMap[char] || char;
            }
            return result;
        });
    }

    // 递归处理节点
    function convertNode(node) {
        if (node.nodeType === Node.TEXT_NODE) {
            if (regex.test(node.nodeValue)) {
                node.nodeValue = convertText(node.nodeValue);
            }
        } else if (node.nodeType === Node.ELEMENT_NODE) {
            const tagName = node.tagName.toLowerCase();
            if (tagName !== 'script' && tagName !== 'style') {
                for (const child of node.childNodes) {
                    convertNode(child);
                }
            }
        }
    }

    // 修复：监听全文档，动态加载的评论也能生效
    function observeDOM() {
        const observer = new MutationObserver((mutations) => {
            for (const mutation of mutations) {
                for (const addedNode of mutation.addedNodes) {
                    convertNode(addedNode);
                }
            }
        });

        observer.observe(document.documentElement, {
            childList: true,
            subtree: true,
            characterData: true
        });
    }

    // 页面加载后执行
    window.addEventListener('load', () => {
        convertNode(document.body);
        observeDOM();
    });
})();