// ==UserScript==
// @name         百家姓智能解密增强版
// @namespace    http://tampermonkey.net/
// @version      0.4.2
// @description  智能识别连续加密文本，≥10字符才解密，链接自动转超链接，40位字符识别为磁力链接
// @author       豆包
// @match        https://www.wnflb2023.com/forum.php?mod=viewthread&tid=*
// @match        https://www.wnflb2023.com/thread*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_registerMenuCommand
// @grant        GM_unregisterMenuCommand
// ==/UserScript==

(function() {
    'use strict';

    // 加密字符表
    const cipher = '赵钱孙李周吴郑王冯陈褚卫蒋沈韩杨朱秦尤许何吕施张孔曹严华金魏陶姜戚谢邹喻福水窦章云苏潘葛奚范彭郎鲁韦昌马苗凤花方俞任袁柳唐罗薛伍余米贝姚孟顾尹江钟竺干';
    // 对应明文字符
    const plain = '0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-_+=/?#%&*:：';

    // 配置项
    const defaultConfig = {
        minLength: 10,               // 最小解密长度
        autoDecrypt: true,          // 自动解密
        showResult: true,           // 显示解密结果
        minCipherRatio: 0.7,        // 最小密文比例（70%以上字符是密文才解密）
        magnetLinkPrefix: 'magnet:?xt=urn:btih:',  // 磁力链接前缀
        resultStyle: {              // 解密结果样式
            background: '#f0f8ff',
            color: '#0066cc',
            padding: '4px 8px',
            margin: '4px 0',
            borderRadius: '4px',
            fontSize: '14px',
            borderLeft: '3px solid #0066cc'
        },
        linkStyle: {                // 链接样式
            color: '#0066cc',
            textDecoration: 'underline',
            fontWeight: 'bold'
        }
    };

    // 加载配置
    let config = { ...defaultConfig };
    try {
        const savedConfig = GM_getValue('config');
        if (savedConfig) {
            config = { ...defaultConfig, ...savedConfig };
        }
    } catch (e) {
        console.log('使用默认配置');
    }

    // 建立映射
    const cipherSet = new Set(cipher);
    const cipherMap = {};
    const reverseMap = {};
    for (let i = 0; i < cipher.length; i++) {
        cipherMap[cipher[i]] = plain[i];
        reverseMap[plain[i]] = cipher[i];
    }

    // 判断文本是否需要解密
    function shouldDecryptText(text) {
        if (!text || text.length < config.minLength) {
            return false;
        }

        // 计算密文字符比例
        let cipherCount = 0;
        for (let ch of text) {
            if (cipherSet.has(ch)) {
                cipherCount++;
            }
        }
        
        const cipherRatio = cipherCount / text.length;
        return cipherRatio >= config.minCipherRatio;
    }

    // 提取文本中的连续密文段
    function extractCipherSegments(text) {
        const segments = [];
        let currentSegment = '';
        let segmentStart = -1;
        
        for (let i = 0; i < text.length; i++) {
            const ch = text[i];
            
            if (cipherSet.has(ch)) {
                // 是密文字符
                if (currentSegment === '') {
                    segmentStart = i;
                }
                currentSegment += ch;
            } else {
                // 不是密文字符，结束当前段
                if (currentSegment !== '') {
                    if (currentSegment.length >= config.minLength && 
                        shouldDecryptText(currentSegment)) {
                        segments.push({
                            text: currentSegment,
                            start: segmentStart,
                            end: i
                        });
                    }
                    currentSegment = '';
                    segmentStart = -1;
                }
            }
        }
        
        // 处理末尾的密文段
        if (currentSegment !== '' && currentSegment.length >= config.minLength && 
            shouldDecryptText(currentSegment)) {
            segments.push({
                text: currentSegment,
                start: segmentStart,
                end: text.length
            });
        }
        
        return segments;
    }

    // 解密单个字符串
    function decodeStr(s) {
        return s.split('').map(ch => cipherMap[ch] ?? ch).join('');
    }

    // 加密函数（用于测试）
    function encodeStr(s) {
        return s.split('').map(ch => reverseMap[ch] ?? ch).join('');
    }

    // 检查是否为磁力链接哈希
    function isMagnetHash(text) {
        const trimmed = text.trim();
        
        // 检查是否为40位字符（常见磁力链接哈希长度）
        if (trimmed.length === 40) {
            // 检查是否只包含十六进制字符（0-9, a-f, A-F）
            return /^[0-9a-fA-F]{40}$/.test(trimmed);
        }
        return false;
    }

    // URL检测
    function isUrl(text) {
        const trimmed = text.trim();
        return /^(https?:\/\/|www\.)/.test(trimmed);
    }

    // 数据URL检测
    function isDataUrl(text) {
        return text.trim().startsWith('data:');
    }

    // 磁力链接检测
    function isMagnetLink(text) {
        const trimmed = text.trim();
        return trimmed.startsWith('magnet:?xt=urn:btih:');
    }

    // 处理解密后的文本，如果是40位字符则添加磁力链接前缀
    function processDecryptedText(text) {
        const trimmed = text.trim();
        
        if (isMagnetHash(trimmed)) {
            // 如果是40位哈希，转换为磁力链接
            return config.magnetLinkPrefix + trimmed;
        } else if (isMagnetLink(trimmed)) {
            // 已经是磁力链接，直接返回
            return trimmed;
        } else if (isUrl(trimmed) || isDataUrl(trimmed)) {
            // 普通URL或数据URL
            return trimmed;
        } else {
            // 其他文本
            return text;
        }
    }

    // 创建解密结果元素
    function createDecryptedElement(originalText) {
        const processedText = processDecryptedText(originalText);
        const isMagnet = isMagnetHash(originalText.trim()) || isMagnetLink(processedText);
        const isUrlText = isUrl(processedText) || isDataUrl(processedText) || isMagnet;
        
        const div = document.createElement('div');
        Object.assign(div.style, config.resultStyle);
        div.className = 'bjm-decrypt-result';
        div.setAttribute('data-bjm-processed', 'true');

        if (isUrlText) {
            const a = document.createElement('a');
            
            if (isMagnet) {
                // 磁力链接特殊处理
                a.href = processedText;
                a.title = '磁力链接';
                a.innerHTML = '🧲 磁力链接：<span class="decrypted-magnet">' + 
                    (originalText.length > 40 ? originalText : processedText) + '</span>';
            } else {
                a.href = processedText;
                a.innerHTML = '🔓 解密链接：<span class="decrypted-url">' + processedText + '</span>';
            }
            
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
            Object.assign(a.style, config.linkStyle);
            a.onclick = (e) => e.stopPropagation();
            div.appendChild(a);

            // 添加磁力链接图标
            if (isMagnet) {
                const magnetIcon = document.createElement('span');
                magnetIcon.innerHTML = ' 🧲';
                magnetIcon.title = '磁力链接';
                a.prepend(magnetIcon);
            }

        } else {
            // 普通文本
            div.innerHTML = '🔓 解密结果：<span class="decrypted-text">' + processedText + '</span>';
        }

        // 添加复制按钮
        const copyBtn = document.createElement('button');
        copyBtn.innerHTML = '📋';
        copyBtn.title = '复制内容';
        copyBtn.style.cssText = 'margin-left:8px;padding:2px 6px;border:1px solid #ccc;background:#fff;border-radius:3px;cursor:pointer;font-size:12px;';
        copyBtn.onclick = (e) => {
            e.stopPropagation();
            const textToCopy = isMagnet ? processedText : processedText;
            navigator.clipboard.writeText(textToCopy).then(() => {
                copyBtn.innerHTML = '✅';
                setTimeout(() => copyBtn.innerHTML = '📋', 1000);
            });
        };
        div.appendChild(copyBtn);

        // 如果是磁力链接，添加额外的哈希显示
        if (isMagnetHash(originalText.trim())) {
            const hashDiv = document.createElement('div');
            hashDiv.style.cssText = 'margin-top:4px;padding:2px 4px;background:#fff8dc;border:1px dashed #ffcc00;border-radius:3px;font-family:monospace;font-size:12px;word-break:break-all;';
            hashDiv.innerHTML = `<span style="color:#666;">哈希值:</span> ${originalText.trim()}`;
            div.appendChild(hashDiv);
        }

        return div;
    }

    // 处理文本节点
    function processTextNode(node) {
        const originalText = node.textContent;
        if (!originalText || originalText.trim().length === 0) {
            return false;
        }

        // 检查是否已经被处理过
        if (node._bjm_processed) {
            return false;
        }

        // 查找连续密文段
        const segments = extractCipherSegments(originalText);
        if (segments.length === 0) {
            node._bjm_processed = true;
            return false;
        }

        const parent = node.parentElement;
        if (!parent || !config.showResult) {
            node._bjm_processed = true;
            return false;
        }

        // 标记节点已处理
        node._bjm_processed = true;
        
        // 对每个密文段进行处理
        let lastIndex = 0;
        const fragment = document.createDocumentFragment();
        let hasDecryption = false;

        for (const segment of segments) {
            // 添加前导普通文本
            if (segment.start > lastIndex) {
                const textBefore = originalText.substring(lastIndex, segment.start);
                fragment.appendChild(document.createTextNode(textBefore));
            }

            // 添加原密文
            const cipherSpan = document.createElement('span');
            cipherSpan.textContent = segment.text;
            cipherSpan.style.color = '#888';
            cipherSpan.className = 'bjm-cipher-text';
            cipherSpan.setAttribute('data-bjm-processed', 'true');
            fragment.appendChild(cipherSpan);

            // 添加解密结果
            const decrypted = decodeStr(segment.text);
            if (decrypted !== segment.text) {
                const resultElement = createDecryptedElement(decrypted);
                fragment.appendChild(resultElement);
                hasDecryption = true;
            }

            lastIndex = segment.end;
        }

        // 添加剩余文本
        if (lastIndex < originalText.length) {
            fragment.appendChild(document.createTextNode(originalText.substring(lastIndex)));
        }

        // 如果有解密内容，替换原节点
        if (hasDecryption) {
            // 将整个父元素标记为已处理
            parent.setAttribute('data-bjm-processed', 'true');
            parent.classList.add('bjm-processed');
            
            try {
                parent.replaceChild(fragment, node);
            } catch (e) {
                console.warn('替换节点失败，可能已被其他脚本修改');
            }
            return true;
        }
        
        return false;
    }

    // 主解密函数
    function decodePage() {
        if (!config.autoDecrypt) return;

        const walker = document.createTreeWalker(
            document.body,
            NodeFilter.SHOW_TEXT,
            {
                acceptNode: function(node) {
                    // 跳过已处理的节点
                    if (node._bjm_processed || 
                        node.parentElement?.hasAttribute('data-bjm-processed') ||
                        node.parentElement?.classList?.contains('bjm-processed')) {
                        return NodeFilter.FILTER_REJECT;
                    }
                    // 跳过脚本、样式等元素
                    if (node.parentElement?.tagName?.match(/^(SCRIPT|STYLE|TEXTAREA|INPUT|BUTTON)/i)) {
                        return NodeFilter.FILTER_REJECT;
                    }
                    // 跳过太短的文本
                    if (!node.textContent || node.textContent.trim().length < config.minLength) {
                        return NodeFilter.FILTER_REJECT;
                    }
                    return NodeFilter.FILTER_ACCEPT;
                }
            }
        );

        const textNodes = [];
        let node;
        while (node = walker.nextNode()) {
            textNodes.push(node);
        }

        // 批量处理，避免频繁DOM操作
        let processedCount = 0;
        for (const node of textNodes) {
            try {
                if (processTextNode(node)) {
                    processedCount++;
                }
            } catch (e) {
                console.error('处理文本节点失败:', e);
                // 标记为已处理，避免重复尝试
                node._bjm_processed = true;
            }
        }
        
        if (processedCount > 0) {
            console.log(`百家姓解密: 处理了 ${processedCount} 个文本节点`);
        }
    }

    // 设置菜单
    function setupMenu() {
