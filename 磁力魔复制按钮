// ==UserScript==
// @name         cilimo磁力魔-竖排磁力按钮一键复制修复版
// @namespace    http://tampermonkey.net/
// @version      3.0
// @description  cilimo网站右侧竖排磁力链接按钮直接复制本条磁力链接，精准提取单条InfoHash
// @author       You
// @match        https://cilimo.com/*
// @grant        GM_setClipboard
// @grant        GM_notification
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';
    // 40位十六进制InfoHash正则
    const HASH_REG = /\b[0-9a-fA-F]{40}\b/;
    // 拼接标准磁力链接
    const getMagnet = hash => `magnet:?xt=urn:btih:${hash}`;

    function processSingleButton(btn) {
        // 已处理过直接跳过
        if (btn._processed) return;
        btn._processed = true;

        // 取消原有跳转链接
        btn.removeAttribute('href');
        btn.style.cursor = 'pointer';
        btn.innerText = '复制磁力';

        // 精准寻找当前按钮所在的整行资源区块
        let itemBlock = btn.parentElement;
        let targetHash = null;

        // 逐层向上遍历，直到找到包含InfoHash的区块
        while (itemBlock) {
            const match = itemBlock.innerText.match(HASH_REG);
            if (match) {
                targetHash = match[0];
                break;
            }
            itemBlock = itemBlock.parentElement;
        }

        if (!targetHash) {
            btn.innerText = '无哈希';
            return;
        }
        const fullMagnet = getMagnet(targetHash);

        // 点击复制事件
        btn.onclick = async function(e) {
            e.preventDefault();
            const defaultText = this.innerText;
            try {
                // 优先油猴剪贴板
                GM_setClipboard(fullMagnet);
                this.innerText = '✅已复制';
                GM_notification({title:"磁力复制成功",timeout:1500});
                console.log("成功复制磁力：", fullMagnet);
            } catch (err) {
                // 浏览器原生剪贴板兜底
                await navigator.clipboard.writeText(fullMagnet);
                this.innerText = '✅已复制';
                console.log("成功复制磁力(原生)：", fullMagnet);
            }
            // 2秒恢复文字
            setTimeout(()=>{
                this.innerText = defaultText;
            },2000);
        };
    }

    // 扫描页面全部磁力按钮
    function scanAllMagnetBtns() {
        const allLinks = document.querySelectorAll('a');
        allLinks.forEach(aTag => {
            const text = aTag.innerText.trim();
            if (text === '磁力链接') {
                processSingleButton(aTag);
            }
        });
    }

    // 防抖函数，避免频繁重复执行
    let timer = null;
    function debounceExec() {
        clearTimeout(timer);
        timer = setTimeout(scanAllMagnetBtns, 300);
    }

    // 初始化执行
    window.addEventListener('load', debounceExec);
    setTimeout(debounceExec, 800);

    // 监听页面动态加载（翻页、AJAX刷新）
    const observer = new MutationObserver(debounceExec);
    observer.observe(document.body, {childList:true,subtree:true});

})();