// ==UserScript==
// @name         cilimo磁力魔-data属性版复制按钮
// @namespace    http://tampermonkey.net/
// @version      4.1
// @description  读取条目data-info-hash属性，改造原有磁力链接按钮复制磁力
// @author       You
// @match        https://cilimo.com/*
// @grant        GM_setClipboard
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';
    const buildMagnet = hash => `magnet:?xt=urn:btih:${hash}`;

    function processBtn(btn) {
        if (btn._processed) return;
        btn._processed = true;
        btn.removeAttribute("href");
        btn.style.cursor = "pointer";
        btn.textContent = "复制磁力";

        // 向上找带data-info-hash的父容器
        let item = btn;
        let targetHash = null;
        while (item) {
            const hash = item.dataset.infoHash;
            if (hash) {
                targetHash = hash;
                break;
            }
            item = item.parentElement;
        }
        if (!targetHash) {
            btn.textContent = "无哈希";
            return;
        }
        const magnet = buildMagnet(targetHash);

        btn.onclick = async e => {
            e.preventDefault();
            const old = btn.textContent;
            try {
                GM_setClipboard(magnet);
                btn.textContent = "✅已复制";
            } catch {
                await navigator.clipboard.writeText(magnet);
                btn.textContent = "✅已复制";
            }
            setTimeout(() => btn.textContent = old, 2000);
        };
    }

    function scanBtns() {
        document.querySelectorAll("a").forEach(a => {
            if (a.innerText.trim() === "磁力链接") processBtn(a);
        });
    }

    let timer;
    function debounce() {
        clearTimeout(timer);
        timer = setTimeout(scanBtns, 250);
    }
    setTimeout(debounce, 600);
    const ob = new MutationObserver(debounce);
    ob.observe(document.body, {childList: true, subtree: true});
})();