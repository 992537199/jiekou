// ==UserScript==
// @name         cilimo磁力魔-劫持JSON获取info_hash一键复制磁力
// @namespace    http://tampermonkey.net/
// @version      4.0
// @description  劫持页面JSON搜索接口，缓存每条info_hash，改造原有磁力链接按钮实现复制
// @author       You
// @match        https://cilimo.com/*
// @grant        GM_setClipboard
// @run-at       document-start
// ==/UserScript==

(function() {
    'use strict';
    // 存储当前页面所有资源 {标题: info_hash}
    const torrentHashMap = new Map();
    // 劫持原生JSON.parse，捕获搜索结果JSON
    const originJSONParse = JSON.parse;
    JSON.parse = function(str) {
        const data = originJSONParse.call(this, str);
        // 判断是搜索结果接口 rsp_228search.json 格式
        if (data && Array.isArray(data.results) && data.results.length > 0 && data.results[0].info_hash) {
            // 清空旧缓存
            torrentHashMap.clear();
            // 存入哈希映射
            data.results.forEach(item => {
                torrentHashMap.set(item.name.trim(), item.info_hash);
            });
            console.log("已缓存所有资源hash", torrentHashMap);
            // 延迟执行按钮改造
            setTimeout(scanAllMagnetBtns, 300);
        }
        return data;
    };

    // 拼接磁力链接
    const buildMagnet = hash => `magnet:?xt=urn:btih:${hash}`;

    // 处理单个磁力按钮
    function processBtn(btn) {
        if (btn._done) return;
        btn._done = true;
        // 清除跳转链接
        btn.removeAttribute("href");
        btn.style.cursor = "pointer";
        btn.textContent = "复制磁力";

        // 向上查找本条资源标题
        let wrap = btn;
        let titleText = "";
        for (let i = 0; i < 10; i++) {
            wrap = wrap.parentElement;
            if (!wrap) break;
            // 取容器内第一行标题文本
            const text = wrap.innerText.split("\n")[0].trim();
            if (text && torrentHashMap.has(text)) {
                titleText = text;
                break;
            }
        }
        if (!titleText || !torrentHashMap.has(titleText)) {
            btn.textContent = "无资源哈希";
            return;
        }
        const hash = torrentHashMap.get(titleText);
        const magnetUrl = buildMagnet(hash);

        // 点击复制
        btn.onclick = async e => {
            e.preventDefault();
            const oldTxt = btn.textContent;
            try {
                GM_setClipboard(magnetUrl);
                btn.textContent = "✅已复制";
                console.log("复制成功：", magnetUrl);
            } catch (err) {
                await navigator.clipboard.writeText(magnetUrl);
                btn.textContent = "✅已复制";
            }
            setTimeout(() => btn.textContent = oldTxt, 2000);
        };
    }

    // 扫描全部磁力链接按钮
    function scanAllMagnetBtns() {
        document.querySelectorAll("a").forEach(a => {
            const txt = a.innerText.trim();
            if (txt === "磁力链接") processBtn(a);
        });
    }

    // DOM监听，翻页/刷新结果自动执行
    const observer = new MutationObserver(() => {
        setTimeout(scanAllMagnetBtns, 200);
    });
    observer.observe(document.body, {childList: true, subtree: true});

})();