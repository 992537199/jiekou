// ==UserScript==
// @name         cilimo 条目内明文InfoHash一键复制磁力按钮
// @namespace    http://tampermonkey.net/
// @version      5.0
// @description  读取每条资源下方明文显示的40位InfoHash，把右侧磁力链接按钮改为复制按钮
// @author       You
// @match        https://cilimo.com/*
// @grant        GM_setClipboard
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';
    // 严格匹配40位十六进制InfoHash
    const HASH_REG = /[0-9a-fA-F]{40}/;
    // 生成标准磁力链接
    const makeMagnet = hash => `magnet:?xt=urn:btih:${hash}`;

    function convertMagnetButton(btn) {
        // 防止重复绑定
        if (btn._fixed) return;
        btn._fixed = true;

        // 取消原跳转链接
        btn.removeAttribute('href');
        btn.style.cursor = 'pointer';
        btn.innerText = '复制磁力';

        // 向上逐级寻找当前整一个资源大区块
        let container = btn.parentElement;
        let targetHash = null;

        // 最多向上10层查找当前资源整块容器
        for (let level = 0; level < 10; level++) {
            if (!container) break;
            // 在当前区块内查找第一个40位哈希
            const allText = container.innerText;
            const hit = allText.match(HASH_REG);
            if (hit) {
                targetHash = hit[0];
                break;
            }
            container = container.parentElement;
        }

        // 没找到哈希就标记
        if (!targetHash) {
            btn.innerText = '无哈希';
            return;
        }
        const magnetLink = makeMagnet(targetHash);

        // 点击复制逻辑
        btn.onclick = async function(e) {
            e.preventDefault();
            const defaultText = this.innerText;
            try {
                GM_setClipboard(magnetLink);
                this.innerText = '✅已复制';
                console.log('本条磁力链接：', magnetLink);
            } catch (err) {
                await navigator.clipboard.writeText(magnetLink);
                this.innerText = '✅已复制';
            }
            setTimeout(() => {
                this.innerText = defaultText;
            }, 2000);
        };
    }

    // 遍历页面所有磁力链接按钮
    function refreshAllButtons() {
        const allA = document.querySelectorAll('a');
        allA.forEach(a => {
            const txt = a.innerText.trim();
            if (txt === '磁力链接') {
                convertMagnetButton(a);
            }
        });
    }

    // 防抖
    let timer = null;
    function debounceRun() {
        clearTimeout(timer);
        timer = setTimeout(refreshAllButtons, 250);
    }

    // 页面加载完成执行
    setTimeout(debounceRun, 600);
    window.addEventListener('load', debounceRun);

    // 监听动态加载
    const observer = new MutationObserver(debounceRun);
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });

})();