// ==UserScript==
// @name         手机编码切换（设置版）
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  手机油猴设置里选编码，解决TVBox接口乱码
// @author       You
// @match        *://*/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_registerMenuCommand
// @run-at       document-start
// ==/UserScript==

(function() {
    'use strict';

    // 读取保存的编码，默认UTF-8
    const defaultCharset = 'UTF-8';
    let currentCharset = GM_getValue('selected_charset', defaultCharset);

    // 强制设置页面编码
    function applyCharset(cs) {
        // 替换或添加meta charset
        let meta = document.querySelector('meta[charset]');
        if (!meta) {
            meta = document.createElement('meta');
            document.head.prepend(meta);
        }
        meta.setAttribute('charset', cs);
        document.charset = cs;
        document.documentElement.charset = cs;
    }

    // 初始加载时应用编码
    applyCharset(currentCharset);

    // 在油猴菜单里添加设置项（手机点脚本→设置可见）
    const charsets = ['UTF-8', 'GBK', 'GB2312', 'ISO-8859-1'];
    charsets.forEach(cs => {
        GM_registerMenuCommand(`编码: ${cs}`, () => {
            GM_setValue('selected_charset', cs);
            currentCharset = cs;
            // 刷新页面生效
            window.location.reload();
        });
    });

})();