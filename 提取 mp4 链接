// ==UserScript==
// @name         福利吧MP4视频复制按钮（修复版）
// @namespace    http://tampermonkey.net/
// @version      2.0
// @description  针对wnflb2023论坛，提取r2video插件MP4，每个视频下方添加复制链接按钮
// @author       You
// @match        https://www.wnflb2023.com/*
// @grant        GM_setClipboard
// ==/UserScript==

(function() {
    'use strict';

    // 防止重复添加按钮的标记
    const markClass = 'r2video_copy_btn_inserted';

    // 提取视频真实mp4地址
    function getVideoMp4(videoEl) {
        // 优先取video自身src
        if (videoEl.src && videoEl.src.includes('.mp4')) {
            return videoEl.src;
        }
        // 兼容<source src="xxx.mp4">子标签
        const sourceList = videoEl.querySelectorAll('source');
        for (const s of sourceList) {
            if (s.src && s.src.includes('.mp4')) {
                return s.src;
            }
        }
        return null;
    }

    // 给所有未处理的video添加复制按钮
    function insertCopyButton() {
        const allVideos = document.querySelectorAll('.r2v-box video, video');
        allVideos.forEach(video => {
            // 已处理过直接跳过
            if (video.classList.contains(markClass)) return;
            const mp4Url = getVideoMp4(video);
            if (!mp4Url) return;

            // 标记已处理
            video.classList.add(markClass);

            // 按钮容器
            const wrap = document.createElement('div');
            wrap.style.margin = '10px 0 20px';
            // 复制按钮
            const copyBtn = document.createElement('button');
            copyBtn.textContent = '复制MP4视频直链';
            copyBtn.style.cssText = `
                padding: 6px 16px;
                background: #007aff;
                color: #fff;
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-size: 14px;
            `;
            copyBtn.onmouseenter = () => copyBtn.style.background = '#005fc8';
            copyBtn.onmouseleave = () => copyBtn.style.background = '#007aff';

            // 复制事件
            copyBtn.onclick = async () => {
                try {
                    GM_setClipboard(mp4Url);
                    // 页面内提示（替代不稳定GM通知）
                    const tip = document.createElement('div');
                    tip.textContent = '✅ 复制成功！';
                    tip.style.cssText = 'color:green;margin-left:10px;display:inline-block;';
                    wrap.appendChild(tip);
                    setTimeout(() => tip.remove(), 1500);
                } catch (err) {
                    // 兜底原生剪贴板
                    await navigator.clipboard.writeText(mp4Url);
                    alert('链接已复制：\n' + mp4Url);
                }
            };

            wrap.appendChild(copyBtn);
            // 插入视频下方
            video.parentNode.insertBefore(wrap, video.nextSibling);
        });
    }

    // 延时多次执行，适配插件延迟渲染
    function delayRun() {
        insertCopyButton();
        setTimeout(insertCopyButton, 800);
        setTimeout(insertCopyButton, 1500);
        setTimeout(insertCopyButton, 3000);
    }

    // 页面DOM加载完成先跑一次
    document.addEventListener('DOMContentLoaded', delayRun);
    window.addEventListener('load', delayRun);

    // 监听页面动态新增内容（翻页、回复加载、插件动态插入视频）
    const observer = new MutationObserver((mutList) => {
        let needRun = false;
        for (const mut of mutList) {
            if (mut.addedNodes.length) {
                needRun = true;
                break;
            }
        }
        if (needRun) insertCopyButton();
    });
    observer.observe(document.body, {
        childList: true,
        subtree: true,
        attributes: false
    });

})();