// ==UserScript==
// @name         视频MP4链接显示（超链接版）
// @namespace    http://tampermonkey.net/
// @version      4.0
// @description  在视频下方直接显示MP4链接（可点击）
// @match        *://*/*
// @run-at       document-end
// ==/UserScript==

(function () {
    'use strict';

    const processed = new WeakSet();

    function addLink(video) {
        if (processed.has(video)) return;
        processed.add(video);

        // ⭐ 直接拿 src（你这个页面就是这种结构）
        let url = video.getAttribute('src') || video.currentSrc;

        if (!url || !url.includes('.mp4')) return;

        // 创建链接元素
        const link = document.createElement('a');
        link.href = url;
        link.innerText = '👉 点击打开视频链接';
        link.target = '_blank';

        // 样式美化
        link.style.display = 'block';
        link.style.margin = '8px 0';
        link.style.color = '#409eff';
        link.style.fontSize = '14px';
        link.style.wordBreak = 'break-all';

        // 也显示完整URL（方便复制）
        const text = document.createElement('div');
        text.innerText = url;
        text.style.fontSize = '12px';
        text.style.color = '#666';
        text.style.wordBreak = 'break-all';

        const wrapper = document.createElement('div');
        wrapper.appendChild(link);
        wrapper.appendChild(text);

        // 插入到视频下方
        video.insertAdjacentElement('afterend', wrapper);
    }

    function run() {
        document.querySelectorAll('video').forEach(addLink);
    }

    // 初始执行
    run();

    // 监听动态加载（论坛必须有）
    new MutationObserver(run).observe(document.body, {
        childList: true,
        subtree: true
    });

})();